<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard Admin</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg-color: #0f172a;
        --card-bg: rgba(30, 41, 59, 0.7);
        --primary: #3b82f6;
        --primary-hover: #2563eb;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --border: rgba(255, 255, 255, 0.1);
        --success: #10b981;
        --danger: #ef4444;
        --warning: #f59e0b;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "Inter", sans-serif;
        background: var(--bg-color);
        background-image:
          radial-gradient(
            at 100% 0%,
            rgba(59, 130, 246, 0.15) 0px,
            transparent 50%
          ),
          radial-gradient(
            at 0% 100%,
            rgba(139, 92, 246, 0.15) 0px,
            transparent 50%
          );
        color: var(--text-main);
        min-height: 100vh;
        padding: 20px;
      }

      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        width: 280px;
        height: 100vh;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(10px);
        border-right: 1px solid var(--border);
        padding: 20px;
        overflow-y: auto;
      }

      .sidebar-header {
        margin-bottom: 32px;
      }

      .sidebar-header h2 {
        font-size: 24px;
        background: linear-gradient(to right, #60a5fa, #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 4px;
      }

      .sidebar-header p {
        color: var(--text-muted);
        font-size: 12px;
      }

      .sidebar-menu {
        list-style: none;
      }

      .sidebar-menu li {
        margin-bottom: 12px;
      }

      .sidebar-menu button {
        width: 100%;
        padding: 12px 16px;
        background: rgba(59, 130, 246, 0.1);
        border: 1px solid transparent;
        border-radius: 8px;
        color: var(--text-main);
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        text-align: left;
      }

      .sidebar-menu button:hover {
        background: rgba(59, 130, 246, 0.2);
        border-color: var(--primary);
      }

      .sidebar-menu button.active {
        background: var(--primary);
        border-color: var(--primary);
      }

      .logout-btn {
        margin-top: 24px;
        padding: 12px 16px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid var(--danger);
        border-radius: 8px;
        color: var(--danger);
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        width: 100%;
      }

      .logout-btn:hover {
        background: rgba(239, 68, 68, 0.2);
      }

      .main-content {
        margin-left: 280px;
      }

      .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
      }

      .header h1 {
        font-size: 32px;
        background: linear-gradient(to right, #60a5fa, #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .admin-badge {
        display: inline-block;
        padding: 6px 16px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid var(--danger);
        border-radius: 20px;
        color: var(--danger);
        font-size: 12px;
        font-weight: 600;
      }

      .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 24px;
        margin-bottom: 32px;
      }

      .card {
        background: var(--card-bg);
        backdrop-filter: blur(16px);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
      }

      .card-icon {
        font-size: 32px;
        margin-bottom: 16px;
      }

      .card h3 {
        font-size: 18px;
        margin-bottom: 8px;
      }

      .card p {
        color: var(--text-muted);
        font-size: 14px;
      }

      .card-value {
        font-size: 24px;
        font-weight: 700;
        color: var(--primary);
        margin-top: 12px;
      }

      .profile-card {
        background: var(--card-bg);
        backdrop-filter: blur(16px);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 32px;
        margin-bottom: 24px;
      }

      .profile-header {
        display: flex;
        align-items: center;
        gap: 24px;
        margin-bottom: 32px;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--border);
      }

      .avatar {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, #ef4444, #f97316);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        font-weight: 700;
      }

      .profile-info h2 {
        font-size: 28px;
        margin-bottom: 8px;
      }

      .profile-info p {
        color: var(--text-muted);
        font-size: 15px;
        margin-bottom: 12px;
      }

      .profile-info .role-badge {
        display: inline-block;
        padding: 6px 16px;
        background: rgba(239, 68, 68, 0.2);
        border: 1px solid var(--danger);
        border-radius: 20px;
        color: var(--danger);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
      }

      .profile-field {
        margin-bottom: 24px;
      }

      .profile-field label {
        display: block;
        color: var(--text-muted);
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .profile-field p {
        color: var(--text-main);
        font-size: 16px;
      }

      .section {
        background: var(--card-bg);
        backdrop-filter: blur(16px);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 24px;
      }

      .section h3 {
        font-size: 20px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .feature-list {
        list-style: none;
      }

      .feature-list li {
        padding: 12px;
        margin-bottom: 8px;
        background: rgba(59, 130, 246, 0.1);
        border-left: 3px solid var(--primary);
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .feature-list li:before {
        content: "✓";
        color: var(--success);
        font-weight: 700;
        font-size: 18px;
      }

      @media (max-width: 768px) {
        .sidebar {
          width: 0;
          z-index: 1000;
          transition: width 0.3s;
        }

        .sidebar.active {
          width: 280px;
        }

        .main-content {
          margin-left: 0;
        }

        .dashboard-grid {
          grid-template-columns: 1fr;
        }

        .profile-header {
          flex-direction: column;
          text-align: center;
        }
      }
    </style>
  </head>
  <body>
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2>🔒 ADMIN</h2>
        <p>Quản trị hệ thống</p>
      </div>

      <ul class="sidebar-menu">
        <li>
          <button class="active" onclick="switchTab('dashboard')">
            📊 Dashboard
          </button>
        </li>
        <li>
          <button onclick="switchTab('rooms')">🏠 Quản lý phòng</button>
        </li>
        <li>
          <button onclick="switchTab('users')">👥 Quản lý người dùng</button>
        </li>
        <li>
          <button onclick="switchTab('cancellation')">
            💸 Hủy phòng & Hoàn cọc
          </button>
        </li>
        <li>
          <button onclick="switchTab('profile')">👤 Hồ sơ của tôi</button>
        </li>
        <li>
          <button onclick="switchTab('settings')">⚙️ Cài đặt hệ thống</button>
        </li>
      </ul>

      <button class="logout-btn" onclick="logout()">🚪 Đăng xuất</button>
    </aside>

    <div class="main-content">
      <div class="header">
        <div>
          <h1 id="pageTitle">📊 Dashboard</h1>
          <span class="admin-badge">ADMIN</span>
        </div>
      </div>

      <!-- Dashboard Tab -->
      <div id="dashboardTab">
        <div class="dashboard-grid">
          <div class="card">
            <div class="card-icon">👥</div>
            <h3>Tổng người dùng</h3>
            <p>Số tài khoản đang hoạt động</p>
            <div class="card-value" id="totalUsers">--</div>
          </div>

          <div class="card">
            <div class="card-icon">✅</div>
            <h3>Người dùng kích hoạt</h3>
            <p>Tài khoản đã xác thực</p>
            <div class="card-value" id="activeUsers">--</div>
          </div>

          <div class="card">
            <div class="card-icon">🔧</div>
            <h3>Nhiệm vụ</h3>
            <p>Công việc cần xử lý</p>
            <div class="card-value">42</div>
          </div>

          <div class="card">
            <div class="card-icon">📈</div>
            <h3>Tăng trưởng</h3>
            <p>Người dùng mới hôm nay</p>
            <div class="card-value">+12</div>
          </div>
        </div>
      </div>

      <!-- Profile Tab -->
      <div id="profileTab" style="display: none">
        <div class="profile-card">
          <div class="profile-header">
            <div class="avatar" id="adminAvatar">A</div>
            <div class="profile-info">
              <h2 id="adminName">Admin User</h2>
              <p id="adminEmail">admin@example.com</p>
              <span class="role-badge">ADMIN</span>
            </div>
          </div>

          <div class="profile-field">
            <label>Email</label>
            <p id="profileEmail">admin@example.com</p>
          </div>

          <div class="profile-field">
            <label>Tên</label>
            <p id="profileName">Admin User</p>
          </div>

          <div class="profile-field">
            <label>Số điện thoại</label>
            <p id="profilePhone">Chưa cập nhật</p>
          </div>

          <div class="profile-field">
            <label>Địa chỉ</label>
            <p id="profileAddress">Chưa cập nhật</p>
          </div>

          <div class="profile-field">
            <label>Quyền</label>
            <p>Quản trị viên hệ thống</p>
          </div>
        </div>
      </div>

      <!-- Users Tab -->
      <div id="usersTab" style="display: none">
        <div class="section">
          <h3>👥 Quản lý người dùng</h3>
          <p style="color: var(--text-muted); margin-bottom: 16px">
            Danh sách tất cả người dùng trong hệ thống
          </p>
          <table
            style="
              width: 100%;
              border-collapse: collapse;
              color: var(--text-main);
            "
          >
            <thead>
              <tr style="border-bottom: 1px solid var(--border)">
                <th
                  style="
                    padding: 12px;
                    text-align: left;
                    color: var(--text-muted);
                    font-weight: 600;
                  "
                >
                  Email
                </th>
                <th
                  style="
                    padding: 12px;
                    text-align: left;
                    color: var(--text-muted);
                    font-weight: 600;
                  "
                >
                  Tên
                </th>
                <th
                  style="
                    padding: 12px;
                    text-align: left;
                    color: var(--text-muted);
                    font-weight: 600;
                  "
                >
                  Trạng thái
                </th>
                <th
                  style="
                    padding: 12px;
                    text-align: left;
                    color: var(--text-muted);
                    font-weight: 600;
                  "
                >
                  Hành động
                </th>
              </tr>
            </thead>
            <tbody id="usersTable">
              <tr>
                <td
                  colspan="4"
                  style="
                    padding: 24px;
                    text-align: center;
                    color: var(--text-muted);
                  "
                >
                  Đang tải dữ liệu...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Settings Tab -->
      <div id="settingsTab" style="display: none">
        <div class="section">
          <h3>⚙️ Cài đặt hệ thống</h3>
          <div style="margin-top: 24px">
            <h4 style="margin-bottom: 16px; font-size: 16px">🛡️ Bảo mật</h4>
            <label
              style="
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 12px;
                cursor: pointer;
              "
            >
              <input
                type="checkbox"
                checked
                style="width: 18px; height: 18px; cursor: pointer"
              />
              <span>Yêu cầu xác thực 2FA</span>
            </label>
            <label
              style="
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 12px;
                cursor: pointer;
              "
            >
              <input
                type="checkbox"
                checked
                style="width: 18px; height: 18px; cursor: pointer"
              />
              <span>Giới hạn rate limit</span>
            </label>
            <label
              style="
                display: flex;
                align-items: center;
                gap: 12px;
                cursor: pointer;
              "
            >
              <input
                type="checkbox"
                checked
                style="width: 18px; height: 18px; cursor: pointer"
              />
              <span>Ghi log toàn bộ hoạt động</span>
            </label>
          </div>

          <div style="margin-top: 32px">
            <h4 style="margin-bottom: 16px; font-size: 16px">📧 Email</h4>
            <label
              style="
                display: flex;
                align-items: center;
                gap: 12px;
                cursor: pointer;
              "
            >
              <input
                type="checkbox"
                checked
                style="width: 18px; height: 18px; cursor: pointer"
              />
              <span>Gửi thông báo qua email</span>
            </label>
          </div>
        </div>
      </div>

      <!-- Rooms Tab -->
      <div id="roomsTab" style="display: none">
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px">
          <!-- Danh sách phòng -->
          <div class="section">
            <h3>🏠 Danh sách phòng trọ</h3>
            <table
              style="
                width: 100%;
                border-collapse: collapse;
                color: var(--text-main);
                margin-top: 16px;
              "
            >
              <thead>
                <tr
                  style="
                    border-bottom: 1px solid var(--border);
                    text-align: left;
                  "
                >
                  <th style="padding: 12px; color: var(--text-muted)">
                    Số phòng
                  </th>
                  <th style="padding: 12px; color: var(--text-muted)">
                    Giá cơ bản
                  </th>
                  <th style="padding: 12px; color: var(--text-muted)">
                    Trạng thái
                  </th>
                  <th style="padding: 12px; color: var(--text-muted)">
                    Khách thuê
                  </th>
                  <th style="padding: 12px; color: var(--text-muted)">
                    Hành động
                  </th>
                </tr>
              </thead>
              <tbody id="roomsTableBody">
                <tr>
                  <td
                    colspan="5"
                    style="
                      padding: 24px;
                      text-align: center;
                      color: var(--text-muted);
                    "
                  >
                    Đang tải dữ liệu phòng...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Thêm phòng mới -->
          <div class="section">
            <h3>➕ Thêm phòng trọ mới</h3>
            <form
              id="createRoomForm"
              onsubmit="handleCreateRoom(event)"
              style="margin-top: 16px"
            >
              <div class="form-group">
                <label>Số phòng</label>
                <input
                  type="text"
                  id="newRoomNumber"
                  placeholder="Ví dụ: 305"
                  required
                  style="
                    width: 100%;
                    padding: 12px 16px;
                    background: rgba(15, 23, 42, 0.6);
                    border: 1px solid var(--border);
                    border-radius: 12px;
                    color: var(--text-main);
                    font-size: 15px;
                    outline: none;
                  "
                />
              </div>
              <div class="form-group" style="margin-top: 12px">
                <label>Giá phòng cơ bản (VND)</label>
                <input
                  type="number"
                  id="newRoomBasePrice"
                  placeholder="Ví dụ: 3000000"
                  required
                  style="
                    width: 100%;
                    padding: 12px 16px;
                    background: rgba(15, 23, 42, 0.6);
                    border: 1px solid var(--border);
                    border-radius: 12px;
                    color: var(--text-main);
                    font-size: 15px;
                    outline: none;
                  "
                />
              </div>
              <div class="form-group" style="margin-top: 12px">
                <label>Trạng thái ban đầu</label>
                <select
                  id="newRoomStatus"
                  style="
                    width: 100%;
                    padding: 12px 16px;
                    background: rgba(15, 23, 42, 0.6);
                    border: 1px solid var(--border);
                    border-radius: 12px;
                    color: var(--text-main);
                    font-size: 15px;
                    outline: none;
                  "
                >
                  <option value="available">Trống (Available)</option>
                  <option value="maintenance">Bảo trì (Maintenance)</option>
                </select>
              </div>
              <button
                class="logout-btn"
                style="
                  margin-top: 20px;
                  background: rgba(59, 130, 246, 0.1);
                  border-color: var(--primary);
                  color: var(--primary);
                "
                type="submit"
              >
                Thêm phòng
              </button>
            </form>
          </div>
        </div>

        <!-- Khung Gán khách thuê -->
        <div
          id="assignTenantSection"
          class="section"
          style="display: none; margin-top: 24px"
        >
          <h3>
            👥 Gán khách thuê vào phòng
            <span id="assignRoomNumber" style="color: var(--primary)"></span>
          </h3>
          <div
            style="
              display: flex;
              gap: 16px;
              align-items: flex-end;
              margin-top: 16px;
            "
          >
            <div class="form-group" style="flex: 1">
              <label
                >Chọn khách thuê (User đã kích hoạt & chưa thuê phòng)</label
              >
              <select
                id="tenantSelect"
                style="
                  width: 100%;
                  padding: 12px 16px;
                  background: rgba(15, 23, 42, 0.6);
                  border: 1px solid var(--border);
                  border-radius: 12px;
                  color: var(--text-main);
                  font-size: 15px;
                  outline: none;
                "
              >
                <option value="">-- Chọn khách thuê --</option>
              </select>
            </div>
            <input type="hidden" id="assignRoomId" />
            <button
              class="logout-btn"
              style="
                width: auto;
                height: 45px;
                margin: 0;
                background: rgba(16, 185, 129, 0.1);
                border-color: var(--success);
                color: var(--success);
              "
              onclick="submitAssignTenant()"
            >
              Xác nhận gán
            </button>
            <button
              class="logout-btn"
              style="width: auto; height: 45px; margin: 0"
              onclick="cancelAssign()"
            >
              Hủy bỏ
            </button>
          </div>
        </div>

        <!-- Khung Chỉnh sửa phòng trọ -->
        <div
          id="editRoomSection"
          class="section"
          style="display: none; margin-top: 24px"
        >
          <h3>
            ✏️ Chỉnh sửa thông tin phòng
            <span
              id="editRoomNumberHeader"
              style="color: var(--primary)"
            ></span>
          </h3>
          <form
            id="editRoomForm"
            onsubmit="submitEditRoom(event)"
            style="
              margin-top: 16px;
              display: grid;
              grid-template-columns: 1fr 1fr 1fr;
              gap: 16px;
              align-items: flex-end;
            "
          >
            <input type="hidden" id="editRoomId" />

            <div class="form-group">
              <label>Số phòng</label>
              <input
                type="text"
                id="editRoomNumber"
                required
                style="
                  width: 100%;
                  padding: 12px 16px;
                  background: rgba(15, 23, 42, 0.6);
                  border: 1px solid var(--border);
                  border-radius: 12px;
                  color: var(--text-main);
                  font-size: 15px;
                  outline: none;
                "
              />
            </div>

            <div class="form-group">
              <label>Giá phòng cơ bản (VND)</label>
              <input
                type="number"
                id="editRoomBasePrice"
                required
                style="
                  width: 100%;
                  padding: 12px 16px;
                  background: rgba(15, 23, 42, 0.6);
                  border: 1px solid var(--border);
                  border-radius: 12px;
                  color: var(--text-main);
                  font-size: 15px;
                  outline: none;
                "
              />
            </div>

            <div class="form-group">
              <label>Trạng thái phòng</label>
              <select
                id="editRoomStatus"
                style="
                  width: 100%;
                  padding: 12px 16px;
                  background: rgba(15, 23, 42, 0.6);
                  border: 1px solid var(--border);
                  border-radius: 12px;
                  color: var(--text-main);
                  font-size: 15px;
                  outline: none;
                "
              >
                <option value="available">Trống (Available)</option>
                <option value="occupied">Đã thuê (Occupied)</option>
                <option value="maintenance">Bảo trì (Maintenance)</option>
              </select>
            </div>

            <div
              style="
                grid-column: span 3;
                display: flex;
                gap: 16px;
                justify-content: flex-end;
                margin-top: 12px;
              "
            >
              <button
                class="logout-btn"
                style="
                  width: auto;
                  height: 45px;
                  margin: 0;
                  background: rgba(16, 185, 129, 0.1);
                  border-color: var(--success);
                  color: var(--success);
                "
                type="submit"
              >
                Lưu chỉnh sửa
              </button>
              <button
                class="logout-btn"
                style="width: auto; height: 45px; margin: 0"
                type="button"
                onclick="cancelEditRoom()"
              >
                Hủy bỏ
              </button>
            </div>
          </form>
